# 复制为 .env 后按需修改：cp .env.example .env  (Windows PowerShell: copy .env.example .env)

# ---- Postgres（docker compose 起容器用）----
POSTGRES_USER=infinite
POSTGRES_PASSWORD=infinite_dev_pw
POSTGRES_DB=infinite_studio

# ---- 后端连库串 ----
# 后端在本机裸跑（不在 compose 网络里），故连 localhost:5432，而非服务名 db。
# 驱动用 psycopg3：app 走 async（postgresql+psycopg://），alembic 同串走 sync。
DATABASE_URL=postgresql+psycopg://infinite:infinite_dev_pw@localhost:5432/infinite_studio

# ---- 前端 ----
# dev 下前端走 vite proxy /api → localhost:8000，故这里给相对前缀即可。
VITE_API_BASE=/api
